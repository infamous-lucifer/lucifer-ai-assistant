{
    "version": "9.2",
    "dependencies": [],
    "dangerPatterns": [
        "rm\\s+-rf?\\s+[~\\/]",
        "curl[^|]*\\|.*sh",
        "wget[^|]*\\|.*sh",
        "dd\\s+if=\\/dev\\/",
        "mkfs",
        ":.*\\{.*:.*\\|.*:.*&.*\\}",
        ">\\s*\\/dev\\/(disk|sda|nvme)",
        "chmod\\s+-R\\s+[67]77\\s+\\/"
    ],
    "tools": [
        {
            "type": "function",
            "function": {
                "name": "run_command",
                "description": "Execute a shell command on macOS. Captures both stdout and stderr. Requires user approval.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "command": { "type": "string" }
                    },
                    "required": ["command"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "list_files",
                "description": "Lists the files in a directory. Use this to understand the project structure and primary language before searching or reading.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "path": { "type": "string", "description": "The directory to list, defaults to '.'" }
                    }
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "search_codebase",
                "description": "Searches for a text string or regex across all files in a directory. Returns file paths and exact line numbers.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "search_term": { "type": "string", "description": "The text to search for" },
                        "path": { "type": "string", "description": "Directory to search, usually '.'" }
                    },
                    "required": ["search_term", "path"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "read_file",
                "description": "Reads a file and returns its content WITH line numbers. Always use this before editing.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "path": { "type": "string" },
                        "start_line": { "type": "number", "description": "Optional starting line" },
                        "end_line": { "type": "number", "description": "Optional ending line" }
                    },
                    "required": ["path"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "search_and_replace",
                "description": "Surgically replace exact text blocks in a file.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "path": { "type": "string" },
                        "search_string": { "type": "string", "description": "The exact literal text to replace." },
                        "replace_string": { "type": "string", "description": "The exact literal text to insert." }
                    },
                    "required": ["path", "search_string", "replace_string"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "control_macos",
                "description": "Safely executes predefined macOS control commands via AppleScript.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "action": { 
                            "type": "string", 
                            "enum": ["get_active_window", "toggle_dark_mode", "get_volume", "set_volume_50", "list_running_apps", "empty_trash"],
                            "description": "The macOS system action to perform"
                        }
                    },
                    "required": ["action"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "propose_fix",
                "description": "Propose a code fix for a specific issue.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "issue": { "type": "string" },
                        "file_path": { "type": "string" },
                        "suggested_fix": { "type": "string" }
                    },
                    "required": ["issue", "file_path", "suggested_fix"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "get_deep_system_report",
                "description": "Comprehensive macOS health report: CPU, RAM, Battery, and Network stats.",
                "parameters": {
                    "type": "object",
                    "properties": {}
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "search_web",
                "description": "Search the web for technical documentation, command syntax, or troubleshooting info. Returns summaries.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "query": { "type": "string" }
                    },
                    "required": ["query"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "keyword_search",
                "description": "Searches for local project code by keywords using a full-text index. Use for finding known terms or variables.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "query": { "type": "string", "description": "The keyword or term to search for (e.g., 'API_KEY')" }
                    },
                    "required": ["query"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "get_command_help",
                "description": "Get a simplified cheat sheet for a specific terminal command.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "command": { "type": "string" }
                    },
                    "required": ["command"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "add_recipe",
                "description": "Save a new recipe to the vault.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "recipe": { "type": "object" }
                    },
                    "required": ["recipe"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "list_recipes",
                "description": "List all recipes in the vault.",
                "parameters": { "type": "object", "properties": {} }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "read_recipe",
                "description": "View a specific recipe.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "title": { "type": "string" }
                    },
                    "required": ["title"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "search_recipes",
                "description": "Find recipes using semantic or lexical search.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "query": { "type": "string" }
                    },
                    "required": ["query"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "import_recipe_from_url",
                "description": "Use Vision to capture a recipe from a web URL.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "url": { "type": "string" }
                    },
                    "required": ["url"]
                }
            }
        }
    ]
}
