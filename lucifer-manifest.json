{
    "version": "7.1",
    "dependencies": [
        {
            "name": "ddgr",
            "binary": "bin/ddgr",
            "source": "https://raw.githubusercontent.com/jarun/ddgr/master/ddgr",
            "sha256": "b26a6d9dbb7260ddd555e8f13e216cd5c3843301ef671be5478caa975060847a",
            "description": "DuckDuckGo CLI for web search"
        },
        {
            "name": "tldr",
            "binary": "bin/tldr",
            "source": "https://raw.githubusercontent.com/raylee/tldr/master/tldr",
            "sha256": "fe1ce2fe8c9c88f0f991b19179ce5e66c013fa299f33cbc974c566d0033e52a8",
            "description": "Simplified community-driven man pages (Cheat sheets)"
        }
    ],
    "dangerPatterns": [
        "rm\\s+-rf?\\s+[~\\/]",
        "curl[^|]*\\|.*sh",
        "wget[^|]*\\|.*sh",
        "dd\\s+if=\\/dev\\/",
        "mkfs",
        ":.*\\{.*:.*\\|.*:.*&.*\\}",
        ">\\s*\\/dev\\/(disk|sda|nvme)",
        "chmod\\s+-R\\s+[67]77\\s+\\/"
    ],
    "tools": [
        {
            "type": "function",
            "function": {
                "name": "run_command",
                "description": "Execute a shell command on macOS. Captures both stdout and stderr. Requires user approval.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "command": { "type": "string" }
                    },
                    "required": ["command"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "list_files",
                "description": "Lists the files in a directory. Use this to understand the project structure and primary language before searching or reading.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "path": { "type": "string", "description": "The directory to list, defaults to '.'" }
                    }
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "search_codebase",
                "description": "Searches for a text string or regex across all files in a directory. Returns file paths and exact line numbers.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "search_term": { "type": "string", "description": "The text to search for" },
                        "path": { "type": "string", "description": "Directory to search, usually '.'" }
                    },
                    "required": ["search_term", "path"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "read_file",
                "description": "Reads a file and returns its content WITH line numbers. Always use this before editing.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "path": { "type": "string" },
                        "start_line": { "type": "number", "description": "Optional starting line" },
                        "end_line": { "type": "number", "description": "Optional ending line" }
                    },
                    "required": ["path"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "edit_file_lines",
                "description": "Replaces a specific range of lines in a file with new content. Replaces the block from start_line to end_line inclusive.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "path": { "type": "string" },
                        "start_line": { "type": "number" },
                        "end_line": { "type": "number" },
                        "new_content": { "type": "string", "description": "The exact new code to insert" }
                    },
                    "required": ["path", "start_line", "end_line", "new_content"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "propose_fix",
                "description": "Propose a code fix for a specific issue.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "issue": { "type": "string" },
                        "file_path": { "type": "string" },
                        "suggested_fix": { "type": "string" }
                    },
                    "required": ["issue", "file_path", "suggested_fix"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "get_deep_system_report",
                "description": "Comprehensive macOS health report: CPU, RAM, Battery, and Network stats.",
                "parameters": {
                    "type": "object",
                    "properties": {}
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "search_web",
                "description": "Search the web for technical documentation, command syntax, or troubleshooting info. Returns summaries.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "query": { "type": "string" }
                    },
                    "required": ["query"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "keyword_search",
                "description": "Searches for local project code by keywords using a full-text index. Use for finding known terms or variables.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "query": { "type": "string", "description": "The keyword or term to search for (e.g., 'API_KEY')" }
                    },
                    "required": ["query"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "get_command_help",
                "description": "Get a simplified cheat sheet for a specific terminal command.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "command": { "type": "string" }
                    },
                    "required": ["command"]
                }
            }
        }
    ]
}
