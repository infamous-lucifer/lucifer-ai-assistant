{
  "name": "lucifer-ai-assistant",
  "version": "1.0.0",
  "type": "module",
  "description": "Command-line AI assistant with screen analysis and web search, optimized for Gemini free tier",
  "main": "dist/index.js",
  "bin": {
    "lucifer": "dist/index.js"
  },
  "scripts": {
    "test": "jest --verbose",
    "start": "npx ts-node index.ts",
    "build": "ncc build index.ts -o dist",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ai",
    "assistant",
    "cli",
    "gemini",
    "screen-analysis",
    "web-search"
  ],
  "author": "Lucifer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/infamous-lucifer/lucifer-ai-assistant.git"
  },
  "bugs": {
    "url": "https://github.com/infamous-lucifer/lucifer-ai-assistant/issues"
  },
  "homepage": "https://github.com/infamous-lucifer/lucifer-ai-assistant#readme",
  "dependencies": {
    "@google/genai": "1.52.0",
    "openai": "6.37.0",
    "chalk": "4.1.2",
    "dotenv": "17.4.2"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@vercel/ncc": "0.38.4",
    "jest": "30.4.2",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "os": [
    "darwin"
  ]
